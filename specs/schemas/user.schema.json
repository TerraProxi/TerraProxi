{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "email",
    "first_name",
    "last_name",
    "role",
    "is_active",
    "gdpr_consent",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "CONSUMER",
        "PRODUCER",
        "ADMIN"
      ]
    },
    "phone": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string",
      "format": "uri"
    },
    "is_active": {
      "type": "boolean"
    },
    "gdpr_consent": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}