{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "consumer_id",
    "producer_id",
    "status",
    "total_price",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "consumer_id": {
      "type": "string"
    },
    "producer_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "PAID",
        "PREPARING",
        "READY",
        "COMPLETED",
        "CANCELLED"
      ]
    },
    "total_price": {
      "type": "number",
      "minimum": 0
    },
    "stripe_payment_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "consumer_name": {
      "type": "string"
    },
    "producer_name": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/OrderItem"
      }
    }
  }
}